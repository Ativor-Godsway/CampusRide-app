# DATABASE_URL must be Neon's POOLED (PgBouncer) endpoint — host ends in
# "-pooler". `pgbouncer=true` tells Prisma to skip named prepared statements
# (required for PgBouncer transaction-mode pooling). `connection_limit` caps
# Prisma's own internal pool — keep this low (e.g. 5) for serverless Neon so
# Prisma doesn't open more connections than the pooler/plan can sustain
# alongside other processes (P2024 "Timed out fetching a new connection from
# the pool" / P1001 "Can't reach database server" both come from this being
# too high or unset).
DATABASE_URL="postgresql://user:password@pooler.host/rida?sslmode=require&pgbouncer=true&connection_limit=5"
# DIRECT_URL must be the non-pooled Neon connection string.
# Used by Prisma for migrations (pooled connections can't run DDL).
# In Neon dashboard: Connection string → toggle "Pooled connection" OFF.
DIRECT_URL="postgresql://user:password@direct.host/rida?sslmode=require"
PORT=3000
NODE_ENV=development

# Secret used to sign access tokens and short-lived OTP-verification tokens.
# Generate a long random value, e.g.: openssl rand -hex 32
JWT_SECRET="replace-with-a-long-random-secret"

# mNotify (real OTP SMS) — only used when MNOTIFY_ENABLED=true (see
# src/services/otp/MnotifyOtpService.ts). Tests and dev default to
# DummyOtpService and never need these.
MNOTIFY_ENABLED=false
MNOTIFY_API_KEY=""
MNOTIFY_SENDER_ID="CampusRide"

# Moolre (real payment collection/disbursement) — only used when
# MOOLRE_ENABLED=true (see src/services/payment/MoolrePaymentService.ts).
# Tests and dev default to DummyPaymentService and never need these.
MOOLRE_ENABLED=false
# https://sandbox.moolre.com for now, https://api.moolre.com for live. Never hardcode.
MOOLRE_BASE_URL="https://sandbox.moolre.com"
# X-API-USER header (username, sent on all calls).
MOOLRE_API_USER=""
# X-API-PUBKEY header — collection calls only.
MOOLRE_PUBLIC_KEY=""
# X-API-KEY header — transfer/disbursement + validate-name. Moves money out;
# the most sensitive secret in the system. Never log, never commit.
MOOLRE_PRIVATE_KEY=""
# Your Moolre account number, sent on all calls.
MOOLRE_ACCOUNT_NUMBER=""
# The `secret` Moolre includes in webhook payloads — verified by
# POST /webhooks/moolre before trusting any webhook.
MOOLRE_WEBHOOK_SECRET=""
# X-API-VASKEY header — SMS (VAS) calls only, e.g. /open/sms/send. A separate
# key from the payment keys above. Never log, never commit.
MOOLRE_VAS_KEY=""
# Sender ID for Moolre SMS — must be pre-registered and approved with Moolre
# before use (same lead-time consideration as the mNotify sender ID).
MOOLRE_SMS_SENDER_ID=""

# Selects the OTP delivery provider: "moolre" | "mnotify" | "dummy" (default).
# See src/services/active.ts for the full precedence/fallback rules.
# - "moolre"  -> MoolreOtpService, only if MOOLRE_ENABLED=true and
#                MOOLRE_VAS_KEY + MOOLRE_SMS_SENDER_ID are set.
# - "mnotify" -> MnotifyOtpService, only if MNOTIFY_ENABLED=true.
# - anything else (incl. unset) -> DummyOtpService (tests/dev default; logs
#                the OTP to the console, never sends a real SMS).
OTP_PROVIDER="dummy"
