{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@rida/shared": ["../../packages/shared/src/index.ts"],
      "@rida/mobile-shared": ["../../packages/mobile-shared/src/index.ts"],
      "@rida/mobile-shared/*": ["../../packages/mobile-shared/src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "../../packages/mobile-shared/src/**/*.ts",
    "../../packages/mobile-shared/src/**/*.tsx"
  ]
}
