{
  "expo": {
    "name": "CampusRide",
    "slug": "campusride-rider",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "campusride-rider",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "gh.edu.ug.rida.rider"
    },
    "android": {
      "package": "gh.edu.ug.rida.rider",
      "adaptiveIcon": {
        "backgroundColor": "#19743C"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "CampusRide uses your location to find the nearest pickup zone."
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "SERVER_URL": "http://localhost:3000"
    }
  }
}
